						"description": "Get notifications for a user"
					}
				},
				{
					"name": "Add Notification",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"userId\": \"user-uuid\",\n  \"type\": \"task_assigned\",\n  \"message\": \"You have been assigned to a new task\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/notifications",
							"host": ["{{base_url}}"],
							"path": ["notifications"]
						},
						"description": "Create a new notification"
