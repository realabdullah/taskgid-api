{
	"info": {
		"_postman_id": "taskgid-api-collection",
		"name": "TaskGid API",
		"description": "API collection for TaskGid - Task Management System",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000/api",
			"type": "string"
		},
		{
			"key": "token",
			"value": "your_jwt_token_here",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123!\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"username\": \"johndoe\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": ["{{base_url}}"],
							"path": ["auth", "register"]
						},
						"description": "Register a new user"
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123!\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": ["{{base_url}}"],
							"path": ["auth", "login"]
						},
						"description": "Login with email and password"
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/auth/logout",
							"host": ["{{base_url}}"],
							"path": ["auth", "logout"]
						},
						"description": "Logout the current user"
					}
				}
			]
		},
		{
			"name": "User Management",
			"item": [
				{
					"name": "Get User Profile",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/users/profile",
							"host": ["{{base_url}}"],
							"path": ["users", "profile"]
						},
						"description": "Get the current user's profile"
					}
				},
				{
					"name": "Update User Profile",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"username\": \"johndoe\",\n  \"email\": \"user@example.com\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/users/profile",
							"host": ["{{base_url}}"],
							"path": ["users", "profile"]
						},
						"description": "Update the current user's profile"
					}
				},
				{
					"name": "Update Profile Picture",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"profilePicture\": \"data:image/jpeg;base64,/9j/4AAQSkZJRg...\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/users/profile/picture",
							"host": ["{{base_url}}"],
							"path": ["users", "profile", "picture"]
						},
						"description": "Update the current user's profile picture"
					}
				}
			]
		},
		{
			"name": "Workspace Management",
			"item": [
				{
					"name": "Create Workspace",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"My Workspace\",\n  \"slug\": \"my-workspace\",\n  \"description\": \"A workspace for my team\",\n  \"team\": [\n    {\n      \"email\": \"team@example.com\"\n    }\n  ]\n}"
						},
						"url": {
							"raw": "{{base_url}}/workspaces",
							"host": ["{{base_url}}"],
							"path": ["workspaces"]
						},
						"description": "Create a new workspace"
					}
				},
				{
					"name": "Get Workspace",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/workspaces/:slug",
							"host": ["{{base_url}}"],
							"path": ["workspaces", ":slug"],
							"variable": [
								{
									"key": "slug",
									"value": "my-workspace"
								}
							]
						},
						"description": "Get workspace details by slug"
					}
				},
				{
					"name": "Update Workspace",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Updated Workspace\",\n  \"description\": \"Updated workspace description\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/workspaces/:slug",
							"host": ["{{base_url}}"],
							"path": ["workspaces", ":slug"],
							"variable": [
								{
									"key": "slug",
									"value": "my-workspace"
								}
							]
						},
						"description": "Update workspace details"
					}
				},
				{
					"name": "Delete Workspace",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/workspaces/:slug",
							"host": ["{{base_url}}"],
							"path": ["workspaces", ":slug"],
							"variable": [
								{
									"key": "slug",
									"value": "my-workspace"
								}
							]
						},
						"description": "Delete a workspace"
					}
				}
			]
		},
		{
			"name": "Task Management",
			"item": [
				{
					"name": "Create Task",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"New Task\",\n  \"description\": \"Task description\",\n  \"dueDate\": \"2024-12-31T23:59:59Z\",\n  \"priority\": \"high\",\n  \"status\": \"todo\",\n  \"assignees\": [\"user-uuid\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/workspaces/:slug/tasks",
							"host": ["{{base_url}}"],
							"path": ["workspaces", ":slug", "tasks"],
							"variable": [
								{
									"key": "slug",
									"value": "my-workspace"
								}
							]
						},
						"description": "Create a new task in a workspace"
					}
				},
				{
					"name": "Update Task",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Updated Task\",\n  \"description\": \"Updated description\",\n  \"status\": \"in_progress\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/workspaces/:slug/tasks/:id",
							"host": ["{{base_url}}"],
							"path": ["workspaces", ":slug", "tasks", ":id"],
							"variable": [
								{
									"key": "slug",
									"value": "my-workspace"
								},
								{
									"key": "id",
									"value": "task-uuid"
								}
							]
						},
						"description": "Update a task"
					}
				},
				{
					"name": "Delete Task",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/workspaces/:slug/tasks/:id",
							"host": ["{{base_url}}"],
							"path": ["workspaces", ":slug", "tasks", ":id"],
							"variable": [
								{
									"key": "slug",
									"value": "my-workspace"
								},
								{
									"key": "id",
									"value": "task-uuid"
								}
							]
						},
						"description": "Delete a task"
					}
				}
			]
		},
		{
			"name": "File Attachments",
			"item": [
				{
					"name": "Upload Task Attachment",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": []
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/workspaces/:id/tasks/:taskId/attachments",
							"host": ["{{base_url}}"],
							"path": ["workspaces", ":id", "tasks", ":taskId", "attachments"],
							"variable": [
								{
									"key": "id",
									"value": "workspace-uuid"
								},
								{
									"key": "taskId",
									"value": "task-uuid"
								}
							]
						},
						"description": "Upload a file attachment to a task"
					}
				},
				{
					"name": "Upload Comment Attachment",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": []
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/workspaces/:id/comments/:commentId/attachments",
							"host": ["{{base_url}}"],
							"path": ["workspaces", ":id", "comments", ":commentId", "attachments"],
							"variable": [
								{
									"key": "id",
									"value": "workspace-uuid"
								},
								{
									"key": "commentId",
									"value": "comment-uuid"
								}
							]
						},
						"description": "Upload a file attachment to a comment"
					}
				},
				{
					"name": "Delete Attachment",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/attachments/:attachmentId",
							"host": ["{{base_url}}"],
							"path": ["attachments", ":attachmentId"],
							"variable": [
								{
									"key": "attachmentId",
									"value": "attachment-uuid"
								}
							]
						},
						"description": "Delete a file attachment"
					}
				}
			]
		},
		{
			"name": "Notifications",
			"item": [
				{
					"name": "Get User Notifications",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/notifications/:userId",
							"host": ["{{base_url}}"],
							"path": ["notifications", ":userId"],
