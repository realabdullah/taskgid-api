				{
					"name": "Delete Notification",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/notifications/:id",
							"host": ["{{base_url}}"],
							"path": ["notifications", ":id"],
							"variable": [
								{
									"key": "id",
									"value": "notification-uuid"
								}
							]
						},
						"description": "Delete a notification"
					}
				}
			]
		}
	]
} 